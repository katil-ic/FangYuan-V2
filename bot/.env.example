# ─────────────────────────────────────────────────────────────────────────────
# FangYuan V2 — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your Discord bot token from https://discord.com/developers/applications
TOKEN=your_bot_token_here

# Bot command prefix (default: !)
PREFIX=!

# Your Discord user ID(s) as owner (comma-separated if multiple)
OWNER_IDS=123456789012345678

# ── CRYPTO APIs ───────────────────────────────────────────────────────────────
# Get free keys at https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_key_here

# Get free keys at https://bscscan.com/apis
BSCSCAN_API_KEY=your_bscscan_key_here

# Get free keys at https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_key_here

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: CoinGecko (crypto prices) works without an API key.
# Blockchain.info (BTC) works without an API key.
# ─────────────────────────────────────────────────────────────────────────────
